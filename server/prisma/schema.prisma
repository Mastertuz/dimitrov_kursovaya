generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  BLOCKED
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

model User {
  id             String        @id @default(cuid())
  fullName       String
  email          String        @unique
  passwordHash   String
  status         AccountStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  roleId         Int
  role           Role          @relation(fields: [roleId], references: [id])
  customerOrders Order[]       @relation("CustomerOrders")
  operatorOrders Order[]       @relation("OperatorOrders")
  auditLogs      AuditLog[]
  aiForecasts    AiForecast[]
  favoriteItems  FavoriteItem[]
  cartItems      CartItem[]
  cartPromo      CartPromo?
  promoUsages    PromoUsage[]

  @@index([roleId])
}

model Role {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String
  description     String?
  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  resource        String
  action          String
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int        @id @default(autoincrement())
  sku         String     @unique
  name        String
  description String?
  image       String?
  price       Decimal    @db.Decimal(10, 2)
  oldPrice    Decimal?   @db.Decimal(10, 2)
  isSale      Boolean    @default(false)
  isNew       Boolean    @default(false)
  sizes       String[]   @default([])
  sizeStock   Json       @default("{}")
  color       String     @default("black")
  material    String     @default("cotton")
  gender      String     @default("unisex")
  season      String     @default("demi")
  brand       String     @default("brand1")
  stock       Int        @default(0)
  categoryId  Int?
  category    Category?  @relation(fields: [categoryId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  orderItems  OrderItem[]
  favoriteItems FavoriteItem[]
  cartItems     CartItem[]

  @@index([categoryId])
}

model Status {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  sortOrder Int
  orders    Order[]
}

model Order {
  id         String      @id @default(cuid())
  customerId String
  customer   User        @relation("CustomerOrders", fields: [customerId], references: [id])
  operatorId String?
  operator   User?       @relation("OperatorOrders", fields: [operatorId], references: [id])
  statusId   Int
  status     Status      @relation(fields: [statusId], references: [id])
  total      Decimal     @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  promoCodeId Int?
  promoCode   PromoCode?  @relation(fields: [promoCodeId], references: [id])
  paymentId   String?     @unique
  paymentStatus String?
  recipientName String?
  recipientPhone String?
  deliveryAddress String?
  deliveryDate DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]
  promoUsages PromoUsage[]

  @@index([customerId])
  @@index([operatorId])
  @@index([statusId])
  @@index([promoCodeId])
}

model PromoCode {
  id             Int               @id @default(autoincrement())
  code           String            @unique
  title          String
  description    String?
  discountType   PromoDiscountType
  discountValue  Decimal           @db.Decimal(10, 2)
  minSubtotal    Decimal?          @db.Decimal(10, 2)
  maxDiscount    Decimal?          @db.Decimal(10, 2)
  usageLimit     Int?
  perUserLimit   Int?              @default(1)
  usedCount      Int               @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  usages         PromoUsage[]
  orders         Order[]
  cartPromos     CartPromo[]

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model PromoUsage {
  id          String    @id @default(cuid())
  promoCodeId Int
  userId      String
  orderId     String?
  createdAt   DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
  @@index([userId])
  @@index([orderId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  size      String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  result    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model AiDataPoint {
  id         String   @id @default(cuid())
  featureSet Json
  target     Float?
  createdAt  DateTime @default(now())
}

model AiForecast {
  id             String   @id @default(cuid())
  inputWindow    Int
  predictedValue Float
  explanation    String?
  createdAt      DateTime @default(now())
  authorId       String?
  author         User?    @relation(fields: [authorId], references: [id])

  @@index([authorId])
}

model FavoriteItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String   @default("M")
  createdAt DateTime @default(now())

  @@unique([userId, productId, size])
  @@index([userId])
  @@index([productId])
  @@index([size])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String   @default("M")
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, size])
  @@index([userId])
  @@index([productId])
  @@index([size])
}

model CartPromo {
  id          String    @id @default(cuid())
  userId      String    @unique
  promoCodeId Int
  appliedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
}